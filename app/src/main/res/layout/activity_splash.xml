<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/BackgroundPrimary"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".activities.ui.inicio.SplashActivity">

    <ImageView
        android:id="@+id/logoPrinci"
        android:layout_width="372dp"
        android:layout_height="416dp"
        android:layout_marginTop="100dp"
        app:srcCompat="@mipmap/ic_launcher_foreground" />

    <TextView
        android:id="@+id/MindSoulHeart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="@string/BienvenidaApp"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold"
        android:layout_marginTop="-68dp"
        app:layout_constraintVertical_bias="0.63" />

    <TextView
        android:id="@+id/CamilaMurcia"
        android:layout_width="137dp"
        android:layout_height="31dp"
        android:fontFamily="@font/italiana"
        android:text="@string/NombreCam"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="italic"
        android:layout_marginStart="90dp"
        android:layout_marginTop="180dp"
        app:layout_constraintVertical_bias="0.767" />
</LinearLayout>