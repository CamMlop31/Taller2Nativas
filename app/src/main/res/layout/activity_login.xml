<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/login"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/BackgroundPrimary"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".activities.ui.auth.Login">

    <LinearLayout
        android:id="@+id/Encabezado"
        android:layout_width="365dp"
        android:layout_height="115dp"
        android:layout_marginTop="-20dp"
        android:layout_marginStart="-20dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/logoHome"
            android:layout_width="136dp"
            android:layout_height="109dp"
            app:srcCompat="@drawable/logo" />

        <TextView
            android:id="@+id/MindSoulHeart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="@string/BienvenidaApp"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

    </LinearLayout>

    <TextView
        android:id="@+id/TtlRegidtro"
        android:layout_width="285dp"
        android:layout_height="61dp"
        android:fontFamily="serif"
        android:layout_marginTop="5dp"
        android:text="@string/MsjInicioSesion"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:textSize="20sp"
        android:textStyle="italic"/>

    <LinearLayout
        android:id="@+id/UsuContraConte"
        android:layout_width="380dp"
        android:layout_height="150dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="-13dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/UsuContra"
            android:layout_width="57dp"
            android:layout_height="130dp"
            android:layout_marginStart="60dp"
            app:srcCompat="@drawable/usucontra" />

        <LinearLayout
            android:layout_width="345dp"
            android:layout_height="150dp"
            android:gravity="center"
            android:orientation="vertical">

            <EditText
                android:id="@+id/Nombre"
                android:layout_width="295dp"
                android:layout_height="49dp"
                android:paddingStart="10dp"
                android:background="@drawable/style_edittext"
                android:ems="10"
                android:hint="@string/NombreLogin"
                android:layout_marginStart="-20dp"
                android:textColor="@color/BackgroundPrimary"/>



            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="295dp"
                android:layout_height="65dp"
                android:layout_marginStart="-20dp"
                app:endIconMode="password_toggle"
                app:endIconTint="@color/BackgroundPrimary"
                app:boxBackgroundMode="none">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/Contra"
                    android:layout_width="295dp"
                    android:layout_height="55dp"
                    android:paddingStart="10dp"
                    android:background="@drawable/style_edittext"
                    android:ems="10"
                    android:hint="@string/contrasena"
                    android:inputType="textPassword"
                    android:textColor="@color/BackgroundPrimary"
                    android:textColorHint="@color/BackgroundPrimary"
                    android:autofillHints="password"/>


            </com.google.android.material.textfield.TextInputLayout>


        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="400dp"
        android:layout_height="330dp"
        android:layout_marginTop="15dp"
        android:gravity="center"
        android:orientation="vertical">

    <Button
        android:id="@+id/btnIngresar"
        android:layout_width="272dp"
        android:layout_height="70dp"
        android:backgroundTint="@color/BackgroundBotones"
        android:fontFamily="serif"
        android:text="@string/btnIngresar"
        android:textSize="28sp"
        android:textStyle="bold"
        app:strokeColor="@color/BordeBotones"
        app:strokeWidth="3dp" />

    <TextView
        android:id="@+id/MsjRecuperaContra"
        android:layout_width="238dp"
        android:layout_height="27dp"
        android:fontFamily="serif"
        android:text="@string/MsjRecuperaContra"
        android:textAlignment="center"
        android:textColor="@color/white"
        android:layout_marginTop="10dp"
        android:textSize="18sp" />

        <TextView
            android:id="@+id/in_huella"
            android:layout_width="238dp"
            android:layout_height="27dp"
            android:text="@string/ingresar_con_huella"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:layout_marginTop="25dp"
            android:textSize="18sp"/>


        <LinearLayout
        android:id="@+id/btnIngresoGoogle"
        android:layout_width="360dp"
        android:layout_height="51dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/style_btn_google"
        android:gravity="start"
        android:orientation="horizontal">

        <ImageView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/google" />

        <TextView
            android:id="@+id/tvIngresoGoogle"
            android:layout_width="277dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginTop="5dp"
            android:fontFamily="@font/tiro_devanagari_hindi"
            android:text="@string/btnIngresGoogle"
            android:textSize="30sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/contenedorRegistro"
        android:layout_width="272dp"
        android:layout_height="50dp"
        android:gravity="start"
        android:orientation="horizontal"
        android:layout_marginTop="10dp">

        <TextView
            android:id="@+id/preguntaRegistro"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/preguntaRegistro"
            android:textColor="@android:color/white"
            android:textSize="18sp"/>

        <TextView
            android:id="@+id/linkRegistro"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:layout_marginStart="8dp"
            android:text="@string/linkRegistro"
            android:textColor="@color/BackgroundBotones"
            android:textSize="18sp"
            android:clickable="true"
            android:focusable="true"/>

    </LinearLayout>

</LinearLayout>

</LinearLayout>